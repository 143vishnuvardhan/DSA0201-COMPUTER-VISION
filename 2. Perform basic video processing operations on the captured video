import cv2
video_path = r"C:\Users\jampa\Downloads\13931625-uhd_2160_3840_24fps.mp4"
print("Select Video Speed")
print("1. Slow Motion")
print("2. Normal Motion")
print("3. Fast Motion")
choice = input("Enter your choice (1/2/3): ")
if choice == "1":
    delay = 100
elif choice == "2":
    delay = 30
elif choice == "3":
    delay = 5
else:
    print("Invalid choice. Playing in normal speed.")
    delay = 30
cap = cv2.VideoCapture(video_path)
while cap.isOpened():
    ret, frame = cap.read()
    if not ret:
        break
    frame = cv2.resize(frame, (800, 600))
    cv2.imshow("Video", frame)
    if cv2.waitKey(delay) & 0xFF == ord('q'):
        break
cap.release()
cv2.destroyAllWindows()
    
 
